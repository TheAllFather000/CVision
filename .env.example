# CVision Environment Variables
# Copy this file to .env and fill in your API keys

# OpenRouter API Key (free models available)
# Sign up at https://openrouter.ai - get free credits
# Used for enhanced scene descriptions (optional - MediaPipe works offline)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Note: Google Places API NOT needed
# We use OpenStreetMap + Nominatim + Overpass (100% free, no key required)
